# =============================================================================
# SICI Web - Variables de Entorno
# =============================================================================
# Copia este archivo a .env y ajusta los valores según tu entorno

# PostgreSQL Configuration (debe coincidir con .env.docker en la raíz)
POSTGRES_USER=sici_user
POSTGRES_PASSWORD=sici_password
POSTGRES_DB=sici_db
POSTGRES_PORT=5433

# Database URL (para Drizzle)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://sici_user:sici_password@localhost:5433/sici_db?schema=public"

# NextAuth Configuration
# Genera un secret aleatorio: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-aleatorio"
NEXTAUTH_URL="http://localhost:3000"

# Gemini AI (opcional, para funcionalidades de IA)
GEMINI_API_KEY=""
