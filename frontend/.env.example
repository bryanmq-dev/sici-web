# =============================================================================
# SICI Web - Variables de Entorno
# =============================================================================
# Copia este archivo a .env y ajusta los valores según tu entorno

# PostgreSQL Configuration (debe coincidir con .env.docker en la raíz)
POSTGRES_USER=sici_user
POSTGRES_PASSWORD=sici_password
POSTGRES_DB=sici_db
POSTGRES_PORT=5433

# Database URL (para Drizzle)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://sici_user:sici_password@localhost:5433/sici_db?schema=public"

# NextAuth Configuration
# Genera un secret aleatorio: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-aleatorio"
NEXTAUTH_URL="http://localhost:3000"
# En producción (VPS): AUTH_URL debe ser la URL pública real (ej. https://soceisi.com),
# si no, los redirects de Auth.js (login, logout) resuelven contra localhost:3000.
# AUTH_TRUST_HOST=true es necesario detrás de un proxy/dominio propio (no Vercel).
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Gemini AI (opcional, para el chatbot SICIBot — se expone al cliente, por eso el prefijo)
NEXT_PUBLIC_GEMINI_API_KEY=""

# SMTP (envío de correos de aprobación/rechazo de solicitudes de ingreso)
# Si se dejan vacíos, el envío se omite (se loguea un warning) sin romper el flujo.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# Strapi CMS (contenido de /comunidad, colección "posts-epc" filtrada por área)
STRAPI_URL="https://cms.soceisi.com"
