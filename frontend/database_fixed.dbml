Table users [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	email varchar [ not null ]
	name varchar [ not null ]
	password_hash varchar [ not null ]
	avatar varchar
	role varchar [ not null, default: 'student', note: 'admin | student' ]
	bio text
	semester int [ note: 'Solo estudiantes (1-10)' ]
	socials jsonb [ default: '{}', note: '{github, linkedin, twitter, website}' ]
	dev_score int
	research_score int
	created_at timestamp [ default: `now()` ]
	updated_at timestamp [ default: `now()` ]

	indexes {
		(email) [ name: 'idx_users_email' ]
		(role) [ name: 'idx_users_role' ]
	}
}

Table sessions [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	user_id uuid
	token varchar [ not null ]
	expires_at timestamp [ not null ]
	created_at timestamp [ default: `now()` ]

	indexes {
		(user_id) [ name: 'idx_sessions_user' ]
		(token) [ name: 'idx_sessions_token' ]
	}
}

Table projects [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	title varchar [ not null ]
	author_id uuid
	description text [ not null ]
	content text
	category varchar
	tags text[] [ default: {} ]
	image varchar
	likes int
	featured boolean [ default: false ]
	created_at timestamp [ default: `now()` ]
	updated_at timestamp [ default: `now()` ]

	indexes {
		(author_id) [ name: 'idx_projects_author' ]
		(category) [ name: 'idx_projects_category' ]
		(featured) [ name: 'idx_projects_featured' ]
	}
}

Table articles [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	title varchar [ not null ]
	abstract text [ not null ]
	content text
	research_area varchar
	author_id uuid
	pdf_url varchar
	image varchar
	likes int
	created_at timestamp [ default: `now()` ]
	updated_at timestamp [ default: `now()` ]
	coauthors_ids uuid[]

	indexes {
		(research_area) [ name: 'idx_articles_area' ]
		(created_at) [ name: 'idx_articles_date' ]
	}
}

Table events [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	title varchar [ not null ]
	description text [ not null ]
	event_date timestamp [ not null ]
	event_type varchar [ not null, note: 'hackathon | webinar | workshop | defense | meetup' ]
	image varchar
	link varchar
	location varchar
	status varchar [ default: 'upcoming', note: 'upcoming | ongoing | completed | cancelled' ]
	created_at timestamp [ default: `now()` ]
	updated_at timestamp [ default: `now()` ]

	indexes {
		(event_date) [ name: 'idx_events_date' ]
		(event_type) [ name: 'idx_events_type' ]
		(status) [ name: 'idx_events_status' ]
	}
}

Table incubator_projects [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	title varchar [ not null ]
	author_id uuid
	description text [ not null ]
	content text
	status varchar [ default: 'Idea', note: 'Idea | Planificación | Prototipado | En Desarrollo | MVP | Lanzado' ]
	categories text[] [ default: {} ]
	technologies text[] [ default: {} ]
	team jsonb [ default: '[]', note: '[{userId, name, role}]' ]
	client varchar
	image varchar
	created_at timestamp [ default: `now()` ]
	updated_at timestamp [ default: `now()` ]

	indexes {
		(author_id) [ name: 'idx_incubator_author' ]
		(status) [ name: 'idx_incubator_status' ]
	}
}

Table mentors [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	user_id uuid
	specialty varchar [ not null ]
	experience text
	mentor_type varchar [ not null, note: 'docente | estudiante' ]
	skills jsonb [ default: '[]', note: '[{name, level}]' ]
	is_active boolean [ default: true ]
	created_at timestamp [ default: `now()` ]
	updated_at timestamp [ default: `now()` ]

	indexes {
		(user_id) [ name: 'idx_mentors_user' ]
		(mentor_type) [ name: 'idx_mentors_type' ]
	}
}

Table mentorship_requests [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	student_id uuid
	mentor_id uuid
	topic varchar [ not null ]
	description text [ not null ]
	tags text[] [ default: {} ]
	status varchar [ default: 'pending', note: 'pending | accepted | completed | rejected' ]
	created_at timestamp [ default: `now()` ]
	updated_at timestamp [ default: `now()` ]

	indexes {
		(student_id) [ name: 'idx_mentorship_student' ]
		(mentor_id) [ name: 'idx_mentorship_mentor' ]
		(status) [ name: 'idx_mentorship_status' ]
	}
}

Table courses [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	name varchar [ not null ]
	description text [ not null ]
	duration varchar
	instructor_id uuid
	syllabus jsonb [ default: '[]', note: '[{title, lessons: []}]' ]
	category varchar
	status varchar [ default: 'active', note: 'active | finished | upcoming' ]
	image varchar
	gallery text[] [ default: {} ]
	objective text
	results text
	relevant_info text
	created_at timestamp [ default: `now()` ]
	updated_at timestamp [ default: `now()` ]

	indexes {
		(instructor_id) [ name: 'idx_courses_instructor' ]
		(category) [ name: 'idx_courses_category' ]
		(status) [ name: 'idx_courses_status' ]
	}
}

Table forum_questions [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	title varchar [ not null ]
	description text [ not null ]
	author_id uuid
	tags text[] [ default: {} ]
	views int
	likes int
	featured_answer_id uuid
	is_solved boolean [ default: false ]
	created_at timestamp [ default: `now()` ]
	updated_at timestamp [ default: `now()` ]

	indexes {
		(author_id) [ name: 'idx_forum_questions_author' ]
		(created_at) [ name: 'idx_forum_questions_date' ]
		(is_solved) [ name: 'idx_forum_questions_solved' ]
	}
}

Table forum_answers [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	question_id uuid
	author_id uuid
	content text [ not null ]
	images text[] [ default: {} ]
	likes int
	created_at timestamp [ default: `now()` ]
	updated_at timestamp [ default: `now()` ]

	indexes {
		(question_id) [ name: 'idx_forum_answers_question' ]
		(author_id) [ name: 'idx_forum_answers_author' ]
	}
}

Table achievements [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	user_id uuid
	title varchar [ not null ]
	icon varchar
	description text
	achieved_at date
	created_at timestamp [ default: `now()` ]

	indexes {
		(user_id) [ name: 'idx_achievements_user' ]
	}
}

Table badges [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	name varchar [ not null ]
	icon varchar
	rarity varchar [ not null, note: 'COMMON | RARE | EPIC | LEGENDARY' ]
	description text
	created_at timestamp [ default: `now()` ]
}

Table user_badges [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	user_id uuid
	badge_id uuid
	unlocked_at timestamp [ default: `now()` ]

	indexes {
		(user_id) [ name: 'idx_user_badges_user' ]
		(badge_id) [ name: 'idx_user_badges_badge' ]
		(user_id) [ name: 'idx_user_badges_unique', unique ]
	}
}

Table quests [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	title varchar [ not null ]
	description text
	category varchar [ not null, note: 'dev | research' ]
	difficulty varchar [ not null, note: 'EASY | MEDIUM | HARD' ]
	dev_reward int
	research_reward int
	is_active boolean [ default: true ]
	created_at timestamp [ default: `now()` ]
	updated_at timestamp [ default: `now()` ]
}

Table user_quests [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	user_id uuid
	quest_id uuid
	status varchar [ default: 'available', note: 'available | active | completed' ]
	progress int
	started_at timestamp
	completed_at timestamp
	created_at timestamp [ default: `now()` ]

	indexes {
		(user_id) [ name: 'idx_user_quests_user' ]
		(quest_id) [ name: 'idx_user_quests_quest' ]
		(status) [ name: 'idx_user_quests_status' ]
	}
}

Table society_units [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	name varchar [ not null, note: 'Directiva | Incubadora | Mentores | Investigaciones' ]
	description text
	created_at timestamp [ default: `now()` ]
}

Table society_memberships [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	user_id uuid
	unit_id uuid
	role varchar [ not null ]
	since date
	is_active boolean [ default: true ]
	created_at timestamp [ default: `now()` ]
	updated_at timestamp [ default: `now()` ]

	indexes {
		(user_id) [ name: 'idx_memberships_user' ]
		(unit_id) [ name: 'idx_memberships_unit' ]
		(user_id) [ name: 'idx_memberships_unique', unique ]
	}
}

Table notifications [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	user_id uuid
	title varchar [ not null ]
	message text [ not null ]
	type varchar [ default: 'info', note: 'info | success | warning | error' ]
	is_read boolean [ default: false ]
	created_at timestamp [ default: `now()` ]

	indexes {
		(user_id) [ name: 'idx_notifications_user' ]
		(is_read) [ name: 'idx_notifications_read' ]
		(created_at) [ name: 'idx_notifications_date' ]
	}
}

Table contact_messages [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	name varchar [ not null ]
	email varchar [ not null ]
	subject varchar
	message text [ not null ]
	is_read boolean [ default: false ]
	created_at timestamp [ default: `now()` ]

	indexes {
		(email) [ name: 'idx_contact_email' ]
		(is_read) [ name: 'idx_contact_read' ]
	}
}

Table join_applications [headercolor: #175e7a] {
	id uuid [ pk, unique, default: `gen_random_uuid()` ]
	full_name varchar [ not null ]
	email varchar [ not null ]
	semester int [ not null ]
	interest_area varchar [ not null ]
	motivation text [ not null ]
	status varchar [ default: 'pending', note: 'pending | approved | rejected' ]
	reviewed_by uuid
	reviewed_at timestamp
	created_at timestamp [ default: `now()` ]

	indexes {
		(email) [ name: 'idx_applications_email' ]
		(status) [ name: 'idx_applications_status' ]
	}
}

Ref fk_users_id_sessions {
	users.id - sessions.user_id [ delete: no action, update: no action ]
}

Ref fk_users_id_projects {
	users.id - projects.author_id [ delete: no action, update: no action ]
}

Ref fk_users_id_incubator_projects {
	users.id - incubator_projects.author_id [ delete: no action, update: no action ]
}

Ref fk_users_id_mentors {
	users.id - mentors.user_id [ delete: no action, update: no action ]
}

Ref fk_users_id_mentorship_requests {
	users.id - mentorship_requests.student_id [ delete: no action, update: no action ]
}

Ref fk_mentors_id_mentorship_requests {
	mentors.id - mentorship_requests.mentor_id [ delete: no action, update: no action ]
}

Ref fk_mentors_id_courses {
	mentors.id - courses.instructor_id [ delete: no action, update: no action ]
}

Ref fk_users_id_forum_questions {
	users.id - forum_questions.author_id [ delete: no action, update: no action ]
}

Ref fk_forum_questions_id_forum_answers {
	forum_questions.id - forum_answers.question_id [ delete: no action, update: no action ]
}

Ref fk_users_id_forum_answers {
	users.id - forum_answers.author_id [ delete: no action, update: no action ]
}

Ref fk_forum_questions_featured_answer_id_forum_answers {
	forum_questions.featured_answer_id > forum_answers.id [ delete: no action, update: no action ]
}

Ref fk_users_id_achievements {
	users.id - achievements.user_id [ delete: no action, update: no action ]
}

Ref fk_users_id_user_badges {
	users.id - user_badges.user_id [ delete: no action, update: no action ]
}

Ref fk_badges_id_user_badges {
	badges.id - user_badges.badge_id [ delete: no action, update: no action ]
}

Ref fk_users_id_user_quests {
	users.id - user_quests.user_id [ delete: no action, update: no action ]
}

Ref fk_quests_id_user_quests {
	quests.id - user_quests.quest_id [ delete: no action, update: no action ]
}

Ref fk_users_id_society_memberships {
	users.id - society_memberships.user_id [ delete: no action, update: no action ]
}

Ref fk_society_units_id_society_memberships {
	society_units.id - society_memberships.unit_id [ delete: no action, update: no action ]
}

Ref fk_users_id_notifications {
	users.id - notifications.user_id [ delete: no action, update: no action ]
}

Ref fk_users_id_join_applications {
	users.id - join_applications.reviewed_by [ delete: no action, update: no action ]
}

Ref fk_users_id_articles {
	users.id < articles.author_id [ delete: no action, update: no action ]
}